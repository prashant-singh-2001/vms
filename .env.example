# Copy this file to .env before running `docker compose up`.

# --- Postgres ---
POSTGRES_USER=vms
POSTGRES_PASSWORD=vms_dev_password
POSTGRES_DB=vms
DATABASE_URL=postgres://vms:vms_dev_password@postgres:5432/vms

# --- Redis (message queue) ---
REDIS_URL=redis://redis:6379

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h

# --- API ---
API_PORT=3000
WORKER_INTERNAL_URL=http://worker:8080

# --- Worker ---
WORKER_HTTP_ADDR=:8080
DETECTOR_URL=http://detector:8000
DEDUP_COOLDOWN_SEC=10
MAX_EVENTS_PER_MIN=6
DETECTION_SAMPLE_FPS=5
WEBRTC_UDP_PORT_MIN=40000
WEBRTC_UDP_PORT_MAX=40100
# Set this to the IP/hostname a browser can reach the worker's WebRTC UDP ports on.
# For local `docker compose up` on your own machine, 127.0.0.1 is correct.
WEBRTC_PUBLIC_IP=127.0.0.1

# --- Detector ---
DETECTOR_PORT=8000
CONFIDENCE_THRESHOLD=0.5
YOLO_MODEL=yolov8n.pt

# --- Frontend ---
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000

# --- Test RTSP source (mediamtx + looping publisher, no real camera needed) ---
MEDIAMTX_RTSP_PORT=8554
# Optional: URL of an mp4 with people in it to loop instead of the synthetic pattern.
# Leave blank to fall back to a generated test pattern (no external dependency).
SAMPLE_VIDEO_URL=

# --- Seed data (created once on first api boot) ---
SEED_USERNAME=demo
SEED_PASSWORD=demo1234
